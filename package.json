{
  "name": "swic",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "start": "web-dev-server --node-resolve --watch",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild-watch.config.mjs",
    "html": "nyc report --reporter=html",
    "test": "web-test-runner --config web-test-runner.config.mjs"
  },
  "devDependencies": {
    "@types/jasmine": "^6.0.0",
    "@web/dev-server": "^0.4.6",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-core": "^0.13.4",
    "esbuild": "^0.28.0",
    "jasmine-core": "^6.2.0",
    "nyc": "^18.0.0",
    "typescript": "^6.0.3",
    "web-test-runner-jasmine": "^0.2.0"
  },
  "dependencies": {
    "@babel/standalone": "8.0.0-rc.4",
    "@jridgewell/trace-mapping": "^0.3.31",
    "idb": "^8.0.3",
    "minimatch": "^10.2.5"
  }
